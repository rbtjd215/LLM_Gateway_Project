# .env.example — 환경 변수 예시 파일
# 실제 사용 시 이 파일을 .env 로 복사하고 값을 수정하세요.
# cp .env.example .env

# ── PostgreSQL ──────────────────────────────
POSTGRES_DB=autocore_db
POSTGRES_USER=autocore_user
POSTGRES_PASSWORD=autocore_pass

# ── FastAPI ────────────────────────────────
DATABASE_URL=postgresql://autocore_user:autocore_pass@db:5432/autocore_db
REDIS_URL=redis://redis:6379

# JWT 시크릿 키 (운영 환경에서는 반드시 복잡한 난수로 교체)
SECRET_KEY=autocore-super-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google Gemini AI ───────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
USE_MOCK_LLM=False

# ── AutoCore V4 Pipeline (Ollama) ────────────
ENGINE_MODE=HF_PIPELINE
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_GUARD_MODEL=qwen2.5:7b
OLLAMA_MASK_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=60
